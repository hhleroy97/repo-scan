{
  "radar_enabled": true,
  "act_enabled": true,
  "test_cmd": "python3 -m pytest -q",
  "llm_roles": {
    "act": "composer-2.5",
    "act_fix": "composer-2.5"
  },
  "max_parallel_acts": 2,
  "max_parallel_loops": 3,
  "act_open_pr": true,
  "gates": { "pre_implement": "auto", "post_implement": "auto" },
  "max_acts_per_day": 50,
  "protected_paths": [".github/*", "repo_scan/config.py"],
  "llm_timeout": 1500,
  "act_timeout": 2700
}
